{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "sf",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "block"
      }
    },
    "block": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "REPEAT",
              "content": {
                "type": "CHOICE",
                "members": [
                  {
                    "type": "SYMBOL",
                    "name": "body_text"
                  },
                  {
                    "type": "SYMBOL",
                    "name": "name_mark"
                  },
                  {
                    "type": "SYMBOL",
                    "name": "writer_mark"
                  }
                ]
              }
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "new_line"
        }
      ]
    },
    "name_mark": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "l_bracket"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "name_text"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "r_bracket"
        }
      ]
    },
    "writer_mark": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "l_brace"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "comment_text"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "r_brace"
        }
      ]
    },
    "l_bracket": {
      "type": "TOKEN",
      "content": {
        "type": "STRING",
        "value": "["
      }
    },
    "r_bracket": {
      "type": "TOKEN",
      "content": {
        "type": "STRING",
        "value": "]"
      }
    },
    "l_brace": {
      "type": "TOKEN",
      "content": {
        "type": "STRING",
        "value": "{"
      }
    },
    "r_brace": {
      "type": "TOKEN",
      "content": {
        "type": "STRING",
        "value": "}"
      }
    },
    "new_line": {
      "type": "TOKEN",
      "content": {
        "type": "STRING",
        "value": "\n"
      }
    },
    "name_text": {
      "type": "TOKEN",
      "content": {
        "type": "REPEAT1",
        "content": {
          "type": "CHOICE",
          "members": [
            {
              "type": "PATTERN",
              "value": "[^{}\\[\\]\\\\\\n]{1,}"
            },
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": "\\"
                },
                {
                  "type": "CHOICE",
                  "members": [
                    {
                      "type": "STRING",
                      "value": "["
                    },
                    {
                      "type": "STRING",
                      "value": "{"
                    },
                    {
                      "type": "STRING",
                      "value": "]"
                    },
                    {
                      "type": "STRING",
                      "value": "}"
                    },
                    {
                      "type": "STRING",
                      "value": "\\"
                    }
                  ]
                }
              ]
            }
          ]
        }
      }
    },
    "comment_text": {
      "type": "TOKEN",
      "content": {
        "type": "REPEAT1",
        "content": {
          "type": "CHOICE",
          "members": [
            {
              "type": "PATTERN",
              "value": "[^{}\\[\\]\\\\]{1,}"
            },
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": "\\"
                },
                {
                  "type": "CHOICE",
                  "members": [
                    {
                      "type": "STRING",
                      "value": "["
                    },
                    {
                      "type": "STRING",
                      "value": "{"
                    },
                    {
                      "type": "STRING",
                      "value": "]"
                    },
                    {
                      "type": "STRING",
                      "value": "}"
                    },
                    {
                      "type": "STRING",
                      "value": "\\"
                    }
                  ]
                }
              ]
            }
          ]
        }
      }
    },
    "body_text": {
      "type": "TOKEN",
      "content": {
        "type": "REPEAT1",
        "content": {
          "type": "CHOICE",
          "members": [
            {
              "type": "PATTERN",
              "value": "[^{}\\[\\]\\n\\\\]+"
            },
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": "\\"
                },
                {
                  "type": "CHOICE",
                  "members": [
                    {
                      "type": "STRING",
                      "value": "["
                    },
                    {
                      "type": "STRING",
                      "value": "{"
                    },
                    {
                      "type": "STRING",
                      "value": "]"
                    },
                    {
                      "type": "STRING",
                      "value": "}"
                    },
                    {
                      "type": "STRING",
                      "value": "\\"
                    }
                  ]
                }
              ]
            }
          ]
        }
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}