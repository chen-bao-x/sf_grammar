{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "sf",
      "camelcase": "Sf",
      "title": "Sf",
      "scope": "source.sf",
      "file-types": [
        "sf"
      ],
      "injection-regex": "^sf$",
      "class-name": "TreeSitterSf"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Sf grammar for tree-sitter",
    "authors": [
      {
        "name": "chenbao",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-sf",
      "funding": ""
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "java": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}